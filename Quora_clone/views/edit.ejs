<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post</title>
</head>
<body>
    <h3>Edit Post</h3>
    <h4>id = <%= post.id %></h4>
    <h4>username = <%= post.username %></h4>
    <form method="post" action="/posts/<%= post.id %>?_method=PATCH">
        <textarea rows="10" cols="20" name="content"><%= post.content %></textarea>
        <br>
        <button>submit</button>
    </form>
</body>
</html>