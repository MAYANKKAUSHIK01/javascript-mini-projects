<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> All users Data </title>
    <style>
        table th,td{
            border: 1px solid black;
        }
    </style>
</head>

<body>
    <table>
        <tr>
            <th>ID</th>
            <th>UserName</th>
            <th>Email</th>
        </tr>
        <% for(user of users) {%>
            <tr>
                <td>
                    <%= user.id %>
                </td>
                <td>
                    <%= user.usernmae %>
                </td>
                <td>
                    <%= user.email %>
                </td>
                <td>
                    <form method="get" action="/users/<%= user.id %>/edit">
                        <button>Edit Username</button>
                    </form>
                </td>
                <td>
                    <form method="get" action="/users/<%= user.id %>/delete">
                        <button>Delete userInfo</button>
                    </form>
                </td>
            </tr>

            <% } %>
    </table>
</body>

</html>